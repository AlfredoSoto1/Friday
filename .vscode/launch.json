{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/backend/bin/Debug/net9.0/Friday.Backend.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "logging": {
        "moduleLoad": false
      }
    },
    {
      "name": "Bot",
      "type": "java",
      "request": "launch",
      "mainClass": "assistant.app.entry.AssistantAppEntry",
      "projectName": "friday-bot",
      "cwd": "${workspaceFolder}/bot",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "bot: build"
    }
  ]
}
