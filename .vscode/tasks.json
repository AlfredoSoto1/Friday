{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/backend/Friday.Backend.csproj",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "base": "$msCompile",
        "severity": "error"
      }
    },
    {
      "label": "bot: build",
      "type": "process",
      "command": "mvn",
      "args": [
        "-f",
        "${workspaceFolder}/bot/pom.xml",
        "package"
      ],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
